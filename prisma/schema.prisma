generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model StripTemplate {
  id              String   @id @default(cuid())
  name            String
  thumbnailUrl    String
  backgroundMode  String   @default("color")
  backgroundValue String
  totalShots      Int      @default(4)
  canvasWidth     Int      @default(300)
  canvasHeight    Int      @default(900)
  elements        Json
  photoPositions  Json
  overlays        Json
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}
